---
import BaseLayout from '../layouts/Base.astro';
---

<BaseLayout 
  title="Jobcoach Website | Professionelle Websites für Karriereberater"
  description="Erstelle deine professionelle Jobcoach-Website in 15 Minuten. DSGVO-konform, mit Impressum-Pflichtfeldern, AVGS-Hinweisen und Zertifizierungs-Badges."
>
  <div class="landing">
    <!-- Hero -->
    <section class="hero">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
      
      <div class="hero-content">
        <span class="badge">Für Jobcoaches & Karriereberater in DACH</span>
        <h1>Deine professionelle<br/><span class="gradient-text">Coach-Website</span><br/>in 15 Minuten</h1>
        <p class="subtitle">
          Automatisiert generiert – mit DSGVO-konformen Elementen, 
          AVGS-Zertifizierungshinweisen und allen wichtigen Features für deine Zielgruppe.
        </p>
        
        <div class="cta-group">
          <a href="/order" class="btn btn-primary">
            <span>Website erstellen</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="#features" class="btn btn-secondary">Mehr erfahren</a>
        </div>
        
        <div class="trust-badges">
          <span class="badge-item">✓ DSGVO-konform</span>
          <span class="badge-item">✓ AVGS-Hinweise</span>
          <span class="badge-item">✓ ICF/DBVC Badges</span>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="features" id="features">
      <h2>Alles, was du für deine Online-Präsenz brauchst</h2>
      
      <div class="bento-grid">
        <div class="bento-card">
          <div class="card-icon">🎯</div>
          <h3>Kompetenz-Darstellung</h3>
          <p>40+ Kompetenz-Optionen für deine Zielgruppe – von Bewerbungsgesprächen bis Leadership-Coaching.</p>
        </div>
        
        <div class="bento-card">
          <div class="card-icon">📍</div>
          <h3>Multi-Location Support</h3>
          <p>Online + physische Standorte. Filterbar nach Ort, Sprache und Kompetenz – perfekt für Local SEO.</p>
        </div>
        
        <div class="bento-card">
          <div class="card-icon">🏆</div>
          <h3>Zertifizierungs-Badges</h3>
          <p>ICF, DBVC, AZWV – zeige deine Qualifikationen transparent und baue Vertrauen auf.</p>
        </div>
        
        <div class="bento-card">
          <div class="card-icon">⚡</div>
          <h3>15-Minuten Setup</h3>
          <p>URL eingeben, Daten prüfen, Design wählen – fertig. Keine technischen Kenntnisse nötig.</p>
        </div>
        
        <div class="bento-card">
          <div class="card-icon">🔒</div>
          <h3>DSGVO-konform</h3>
          <p>Cookie-Consent, Impressum-Pflichtfelder und Datenschutzerklärung – alles integriert.</p>
        </div>
        
        <div class="bento-card highlight">
          <div class="card-icon">💰</div>
          <h3>Transparent Pricing</h3>
          <p>Starter €49/Monat · Pro €99/Monat · Premium €199/Monat</p>
          <a href="/order" class="btn-small">Jetzt starten →</a>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="how-it-works">
      <h2>So funktioniert's</h2>
      
      <div class="steps">
        <div class="step">
          <div class="step-number">1</div>
          <div class="step-content">
            <h3>URL eingeben oder Daten eingeben</h3>
            <p>Scrapen wir deine bestehende Website oder LinkedIn-Profil – oder fülle unser einfaches Formular aus.</p>
          </div>
        </div>
        
        <div class="step">
          <div class="step-number">2</div>
          <div class="step-content">
            <h3>Design & Paket wählen</h3>
            <p>Wähle aus 5 Template-Varianten (Corporate, Modern, Minimal, Warm, Premium) und deinem passenden Paket.</p>
          </div>
        </div>
        
        <div class="step">
          <div class="step-number">3</div>
          <div class="step-content">
            <h3>Website erhalten</h3>
            <p>In 15 Minuten ist deine professionelle Coach-Website live – bereit für deine Klienten.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <h2>Bereit für deine neue Website?</h2>
      <p>Joine die ersten Jobcoaches, die ihre Online-Präsenz automatisiert haben.</p>
      <a href="/order" class="btn btn-primary btn-large">
        Jetzt Website erstellen
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <p>© 2026 Change-to-Impact · Für Jobcoaches in Deutschland, Österreich und der Schweiz</p>
      <p class="legal-links">
        <a href="/impressum">Impressum</a> · <a href="/datenschutz">Datenschutz</a>
      </p>
    </footer>
  </div>
</BaseLayout>

<style is:global>
  :root {
    --primary: #6366f1;
    --primary-dark: #4f46e5;
    --accent: #22d3ee;
    --bg-dark: #0f172a;
    --bg-card: rgba(30, 41, 59, 0.8);
    --text: #f1f5f9;
    --text-muted: #94a3b8;
  }
  
  * { margin: 0; padding: 0; box-sizing: border-box; }
  
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: var(--bg-dark);
    color: var(--text);
    line-height: 1.6;
  }
  
  .gradient-text {
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 12px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }
  
  .btn-primary {
    background: linear-gradient(135deg, var(--primary), var(--primary-dark));
    color: white;
    box-shadow: 0 4px 20px rgba(99, 102, 241, 0.4);
  }
  
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(99, 102, 241, 0.5);
    text-decoration: none;
  }
  
  .btn-secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid rgba(255,255,255,0.2);
  }
  
  .btn-secondary:hover {
    background: rgba(255,255,255,0.1);
    text-decoration: none;
  }
  
  .btn-large { padding: 18px 36px; font-size: 1.1rem; }
  .btn-small { padding: 8px 16px; font-size: 0.9rem; }
</style>

<style>
  .landing {
    min-height: 100vh;
    overflow-x: hidden;
  }
  
  /* Hero */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    background: radial-gradient(ellipse at 50% 0%, rgba(99,102,241,0.15) 0%, transparent 60%);
  }
  
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.5;
    animation: float 8s ease-in-out infinite;
  }
  
  .orb-1 {
    width: 400px; height: 400px;
    background: var(--primary);
    top: -100px; left: -100px;
    animation-delay: 0s;
  }
  
  .orb-2 {
    width: 300px; height: 300px;
    background: var(--accent);
    bottom: -50px; right: -50px;
    animation-delay: -3s;
  }
  
  .orb-3 {
    width: 200px; height: 200px;
    background: #f472b6;
    top: 40%; left: 60%;
    animation-delay: -5s;
  }
  
  @keyframes float {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(20px, -20px); }
  }
  
  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
    text-align: center;
  }
  
  .badge {
    display: inline-block;
    padding: 8px 16px;
    background: rgba(99,102,241,0.2);
    border: 1px solid rgba(99,102,241,0.3);
    border-radius: 100px;
    font-size: 0.85rem;
    color: var(--accent);
    margin-bottom: 2rem;
  }
  
  .hero h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }
  
  .subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto 2rem;
  }
  
  .cta-group {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  
  .trust-badges {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  
  /* Features */
  .features {
    padding: 6rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .features h2 {
    font-size: 2.5rem;
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  
  .bento-card {
    background: var(--bg-card);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 2rem;
    transition: all 0.3s ease;
  }
  
  .bento-card:hover {
    transform: translateY(-4px);
    border-color: rgba(99,102,241,0.5);
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }
  
  .bento-card.highlight {
    background: linear-gradient(135deg, rgba(99,102,241,0.2), rgba(34,211,238,0.1));
    border-color: rgba(99,102,241,0.3);
    grid-column: span 1;
  }
  
  .card-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }
  
  .bento-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }
  
  .bento-card p {
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  
  /* How it works */
  .how-it-works {
    padding: 6rem 2rem;
    max-width: 900px;
    margin: 0 auto;
  }
  
  .how-it-works h2 {
    font-size: 2.5rem;
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .steps {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  
  .step {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }
  
  .step-number {
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.25rem;
    flex-shrink: 0;
  }
  
  .step-content h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }
  
  .step-content p {
    color: var(--text-muted);
  }
  
  /* CTA Section */
  .cta-section {
    padding: 6rem 2rem;
    text-align: center;
    background: radial-gradient(ellipse at 50% 100%, rgba(99,102,241,0.15) 0%, transparent 60%);
  }
  
  .cta-section h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }
  
  .cta-section p {
    color: var(--text-muted);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }
  
  /* Footer */
  .footer {
    padding: 2rem;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  
  .footer .legal-links {
    margin-top: 0.75rem;
  }
  
  .footer .legal-links a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.3s ease;
  }
  
  .footer .legal-links a:hover {
    color: var(--accent);
  }
  
  /* Responsive */
  @media (max-width: 768px) {
    .hero { min-height: 80vh; padding: 3rem 1.5rem; }
    .hero h1 { font-size: 2rem; }
    .subtitle { font-size: 1.1rem; }
    .features, .how-it-works, .cta-section { padding: 4rem 1.5rem; }
    .features h2, .how-it-works h2, .cta-section h2 { font-size: 1.75rem; }
    .bento-grid { grid-template-columns: 1fr; }
  }
</style>
