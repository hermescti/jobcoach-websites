---
import BaseLayout from '../layouts/Base.astro';
---

<BaseLayout title="Website bestellen | Jobcoach Hub" description="Bestelle deine professionelle Jobcoach-Website in wenigen Minuten">
  <div class="order-container">
    <!-- Header -->
    <header class="order-header">
      <h1>Website bestellen</h1>
      <p class="subtitle">Erstelle deine professionelle Jobcoach-Website in 5 Minuten</p>
      <div class="progress-bar">
        <div class="progress-fill" id="progress"></div>
      </div>
      <div class="step-indicators">
        <span class="step active" data-step="1">1</span>
        <span class="step" data-step="2">2</span>
        <span class="step" data-step="3">3</span>
        <span class="step" data-step="4">4</span>
        <span class="step" data-step="5">5</span>
      </div>
    </header>

    <!-- Form -->
    <form id="order-form" class="order-form" action="/api/order" method="POST">
      
      <!-- Schritt 1: Basis-Info -->
      <fieldset class="form-step" data-step="1">
        <legend>Basis-Informationen</legend>
        
        <div class="form-group">
          <label for="fullName">Vollständiger Name *</label>
          <input 
            type="text" 
            id="fullName" 
            name="fullName" 
            required 
            placeholder="z.B. Dr. Maria Schmidt"
            autocomplete="name"
          />
          <span class="hint">Wie du auf der Website genannt werden möchtest</span>
        </div>

        <div class="form-group">
          <label for="title">Beruflicher Titel *</label>
          <input 
            type="text" 
            id="title" 
            name="title" 
            required 
            placeholder="z.B. Zertifizierter Karriereberater & Coach"
          />
          <span class="hint">Deine Hauptbezeichnung für die Website</span>
        </div>

        <div class="form-group">
          <label for="certifications">Zertifizierungen</label>
          <textarea 
            id="certifications" 
            name="certifications" 
            maxlength="500"
            placeholder="z.B. ICF ACC, DHV zertifiziert, NLP Master Practitioner..."
            rows="3"
          ></textarea>
          <span class="hint"><span id="cert-count">0</span>/500 Zeichen</span>
        </div>

        <div class="form-group">
          <label for="specialization">Spezialisierung *</label>
          <select id="specialization" name="specialization" required>
            <option value="">Bitte wählen...</option>
            <option value="career-coaching">Karriere-Coaching</option>
            <option value="executive-coaching">Executive Coaching</option>
            <option value="outplacement">Outplacement</option>
            <option value="bewerbercoaching">Bewerbercoaching</option>
            <option value="leadership">Leadership Development</option>
            <option value="team-coaching">Team-Coaching</option>
            <option value="general">Generalist</option>
          </select>
          <span class="hint">Bestimmt das empfohlene Template</span>
        </div>

        <div class="form-group">
          <label for="experience">Berufserfahrung (Jahre) *</label>
          <input 
            type="number" 
            id="experience" 
            name="experience" 
            required 
            min="0"
            max="50"
            placeholder="z.B. 10"
          />
        </div>

        <div class="form-nav">
          <button type="button" class="btn btn-next" onclick="nextStep(2)">Weiter</button>
        </div>
      </fieldset>

      <!-- Schritt 2: Kompetenzen -->
      <fieldset class="form-step" data-step="2" hidden>
        <legend>Kompetenzen & Angebote</legend>
        <p class="step-description">Wähle alle Kompetenzen aus, die du anbietest (Mehrfachauswahl)</p>
        
        <div class="competency-grid">
          <label class="competency-option">
            <input type="checkbox" name="competencies" value="karriereberatung" />
            <span>Karriereberatung</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="bewerbungscoaching" />
            <span>Bewerbungscoaching</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="lebenslauf-optimierung" />
            <span>Lebenslauf-Optimierung</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="anschreiben" />
            <span>Anschreiben-Training</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="interview-coaching" />
            <span>Interview-Coaching</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="gehaltsverhandlung" />
            <span>Gehaltsverhandlung</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="linkedin-optimierung" />
            <span>LinkedIn-Optimierung</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="networking" />
            <span>Networking-Strategien</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="fuehrungskraefte" />
            <span>Führungskräfte-Coaching</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="team-development" />
            <span>Teamentwicklung</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="konfliktmanagement" />
            <span>Konfliktmanagement</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="stressmanagement" />
            <span>Stressmanagement</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="work-life-balance" />
            <span>Work-Life-Balance</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="burnout-praevention" />
            <span>Burnout-Prävention</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="change-management" />
            <span>Change Management</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="outplacement" />
            <span>Outplacement</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="wiedereinstieg" />
            <span>Wiedereinstieg</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="berufsorientierung" />
            <span>Berufsorientierung</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="staerken-analyse" />
            <span>Stärken-Analyse</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="werte-coaching" />
            <span>Werte-Coaching</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="zielsetzung" />
            <span>Zielsetzung & Planung</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="selbstmarketing" />
            <span>Selbstmarketing</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="personal-branding" />
            <span>Personal Branding</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="online-presence" />
            <span>Online-Presence</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="videocoaching" />
            <span>Video-Coaching</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="group-coaching" />
            <span>Group Coaching</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="workshops" />
            <span>Workshops & Seminare</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="webinare" />
            <span>Webinare</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="assessment-center" />
            <span>Assessment Center Prep</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="case-studies" />
            <span>Case Studies</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="pitch-training" />
            <span>Pitch-Training</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="praesentation" />
            <span>Präsentationstraining</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="kommunikation" />
            <span>Kommunikationstraining</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="verhandlung" />
            <span>Verhandlungstraining</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="zeitmanagement" />
            <span>Zeitmanagement</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="produktivitaet" />
            <span>Produktivität</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="resilienz" />
            <span>Resilienz-Training</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="mindfulness" />
            <span>Mindfulness Coaching</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="emotional-intelligence" />
            <span>Emotionale Intelligenz</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="diversity" />
            <span>Diversity & Inclusion</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="interkulturell" />
            <span>Interkulturelles Coaching</span>
          </label>

          <label class="competency-option">
            <input type="checkbox" name="competencies" value="sprachen" />
            <span>Mehrsprachig</span>
          </label>
        </div>

        <div class="form-group">
          <label for="otherCompetencies">Weitere Kompetenzen (Optional)</label>
          <textarea 
            id="otherCompetencies" 
            name="otherCompetencies" 
            maxlength="300"
            placeholder="Kompetenzen, die nicht in der Liste sind..."
            rows="2"
          ></textarea>
        </div>

        <div class="form-nav">
          <button type="button" class="btn btn-prev" onclick="prevStep(1)">Zurück</button>
          <button type="button" class="btn btn-next" onclick="nextStep(3)">Weiter</button>
        </div>
      </fieldset>

      <!-- Schritt 3: Standorte & Sprachen -->
      <fieldset class="form-step" data-step="3" hidden>
        <legend>Standorte & Sprachen</legend>
        
        <div class="form-group">
          <label>Coaching-Modi *</label>
          <div class="checkbox-group">
            <label class="checkbox-label">
              <input type="checkbox" id="mode-online" name="coachingModes" value="online" required />
              <span>Online-Coaching</span>
            </label>
            <label class="checkbox-label">
              <input type="checkbox" id="mode-onsite" name="coachingModes" value="onsite" />
              <span>Vor-Ort-Coaching</span>
            </label>
            <label class="checkbox-label">
              <input type="checkbox" id="mode-hybrid" name="coachingModes" value="hybrid" />
              <span>Hybrid (Online + Vor-Ort)</span>
            </label>
          </div>
        </div>

        <div class="form-group" id="physical-locations" hidden>
          <label>Physische Standorte</label>
          <div class="location-entry">
            <input type="text" name="locationCity[]" placeholder="Stadt" />
            <input type="text" name="locationCountry[]" placeholder="Land" />
          </div>
          <button type="button" class="btn btn-small" onclick="addLocationField()">+ Weitere Location</button>
        </div>

        <div class="form-group">
          <label for="languages">Sprachen *</label>
          <select id="languages" name="languages" multiple required size="5">
            <option value="deutsch">Deutsch</option>
            <option value="englisch">Englisch</option>
            <option value="franzoesisch">Französisch</option>
            <option value="spanisch">Spanisch</option>
            <option value="italienisch">Italienisch</option>
            <option value="portugiesisch">Portugiesisch</option>
            <option value="niederlaendisch">Niederländisch</option>
            <option value="polnisch">Polnisch</option>
            <option value="tuerkisch">Türkisch</option>
            <option value="arabisch">Arabisch</option>
            <option value="chinesisch">Chinesisch</option>
            <option value="japanisch">Japanisch</option>
            <option value="russisch">Russisch</option>
            <option value="andere">Andere</option>
          </select>
          <span class="hint">Strg/Cmd + Klick für Mehrfachauswahl</span>
        </div>

        <div class="form-group">
          <label for="otherLanguages">Weitere Sprachen (Optional)</label>
          <input 
            type="text" 
            id="otherLanguages" 
            name="otherLanguages" 
            placeholder="z.B. Schwedisch, Dänisch..."
          />
        </div>

        <div class="form-nav">
          <button type="button" class="btn btn-prev" onclick="prevStep(2)">Zurück</button>
          <button type="button" class="btn btn-next" onclick="nextStep(4)">Weiter</button>
        </div>
      </fieldset>

      <!-- Schritt 4: Kontakt & Social -->
      <fieldset class="form-step" data-step="4" hidden>
        <legend>Kontakt & Social Media</legend>
        
        <div class="form-group">
          <label for="email">Email-Adresse *</label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            required 
            placeholder="deine@email.com"
          />
        </div>

        <div class="form-group">
          <label for="phone">Telefon *</label>
          <input 
            type="tel" 
            id="phone" 
            name="phone" 
            required 
            placeholder="+49 123 456789"
          />
        </div>

        <div class="form-group">
          <label for="linkedin">LinkedIn URL</label>
          <input 
            type="url" 
            id="linkedin" 
            name="linkedin" 
            placeholder="https://linkedin.com/in/deinprofil"
          />
        </div>

        <div class="form-group">
          <label for="xing">XING URL</label>
          <input 
            type="url" 
            id="xing" 
            name="xing" 
            placeholder="https://xing.com/profile/deinprofil"
          />
        </div>

        <div class="form-group">
          <label for="calendly">Calendly URL (Optional)</label>
          <input 
            type="url" 
            id="calendly" 
            name="calendly" 
            placeholder="https://calendly.com/deinname"
          />
          <span class="hint">Für direkte Terminbuchung</span>
        </div>

        <div class="form-group">
          <label for="website">Bestehende Website (Optional)</label>
          <input 
            type="url" 
            id="website" 
            name="website" 
            placeholder="https://deine-website.de"
          />
          <span class="hint">Falls vorhanden</span>
        </div>

        <div class="form-nav">
          <button type="button" class="btn btn-prev" onclick="prevStep(3)">Zurück</button>
          <button type="button" class="btn btn-next" onclick="nextStep(5)">Weiter</button>
        </div>
      </fieldset>

      <!-- Schritt 5: Template & Paket -->
      <fieldset class="form-step" data-step="5" hidden>
        <legend>Template & Paket-Auswahl</legend>
        
        <div class="template-grid">
          <label class="template-option">
            <input type="radio" name="template" value="executive" required />
            <div class="template-preview executive">
              <div class="preview-colors">
                <span class="color" style="background: #1e3a5f"></span>
                <span class="color" style="background: #c9a959"></span>
                <span class="color" style="background: #f5f5f5"></span>
              </div>
              <span class="template-name">Executive</span>
            </div>
          </label>

          <label class="template-option">
            <input type="radio" name="template" value="modern" />
            <div class="template-preview modern">
              <div class="preview-colors">
                <span class="color" style="background: #2563eb"></span>
                <span class="color" style="background: #10b981"></span>
                <span class="color" style="background: #f3f4f6"></span>
              </div>
              <span class="template-name">Modern</span>
            </div>
          </label>

          <label class="template-option">
            <input type="radio" name="template" value="minimal" />
            <div class="template-preview minimal">
              <div class="preview-colors">
                <span class="color" style="background: #111827"></span>
                <span class="color" style="background: #6b7280"></span>
                <span class="color" style="background: #ffffff"></span>
              </div>
              <span class="template-name">Minimal</span>
            </div>
          </label>

          <label class="template-option">
            <input type="radio" name="template" value="warm" />
            <div class="template-preview warm">
              <div class="preview-colors">
                <span class="color" style="background: #d97706"></span>
                <span class="color" style="background: #78350f"></span>
                <span class="color" style="background: #fef3c7"></span>
              </div>
              <span class="template-name">Warm & Friendly</span>
            </div>
          </label>
        </div>

        <div class="form-group">
          <label>Paket-Auswahl *</label>
          <div class="pricing-selector">
            <label class="pricing-option">
              <input type="radio" name="package" value="starter" required />
              <div class="pricing-card">
                <h4>Starter</h4>
                <div class="price">€29<span>/Monat</span></div>
                <ul>
                  <li>✓ 1 Template</li>
                  <li>✓ Subdomain</li>
                  <li>✓ Kontaktformular</li>
                  <li>✓ Mobile Optimized</li>
                </ul>
              </div>
            </label>

            <label class="pricing-option">
              <input type="radio" name="package" value="pro" />
              <div class="pricing-card featured">
                <div class="badge">Beliebt</div>
                <h4>Pro</h4>
                <div class="price">€49<span>/Monat</span></div>
                <ul>
                  <li>✓ Alle Templates</li>
                  <li>✓ Eigene Domain</li>
                  <li>✓ Calendly Integration</li>
                  <li>✓ SEO-Tools</li>
                  <li>✓ Analytics</li>
                </ul>
              </div>
            </label>

            <label class="pricing-option">
              <input type="radio" name="package" value="premium" />
              <div class="pricing-card">
                <h4>Premium</h4>
                <div class="price">€79<span>/Monat</span></div>
                <ul>
                  <li>✓ Alles aus Pro</li>
                  <li>✓ Blog-System</li>
                  <li>✓ Email-Marketing</li>
                  <li>✓ Priority Support</li>
                  <li>✓ Monthly Review</li>
                </ul>
              </div>
            </label>
          </div>
        </div>

        <div class="form-group">
          <label for="domain">Eigene Domain (Optional)</label>
          <input 
            type="text" 
            id="domain" 
            name="domain" 
            placeholder="www.dein-name.de"
          />
          <span class="hint">Falls vorhanden, verknüpfen wir sie kostenlos</span>
        </div>

        <div class="form-group">
          <label for="requests">Besondere Anforderungen?</label>
          <textarea 
            id="requests" 
            name="requests" 
            maxlength="1000"
            placeholder="Spezielle Farben, Layout-Wünsche, besondere Features..."
            rows="3"
          ></textarea>
          <span class="hint"><span id="requests-count">0</span>/1000 Zeichen</span>
        </div>

        <div class="form-group">
          <label class="checkbox-label">
            <input type="checkbox" name="terms" required />
            <span>Ich akzeptiere die <a href="/agb" target="_blank">AGB</a> *</span>
          </label>
        </div>

        <div class="form-nav">
          <button type="button" class="btn btn-prev" onclick="prevStep(4)">Zurück</button>
          <button type="submit" class="btn btn-primary btn-submit">Jetzt bestellen</button>
        </div>
      </fieldset>

    </form>

    <!-- Success Message -->
    <div id="success-message" class="success-message" hidden>
      <div class="success-icon">✓</div>
      <h2>Vielen Dank!</h2>
      <p>Deine Bestellung wurde erfolgreich übermittelt.</p>
      <p>Wir melden uns innerhalb von 24 Stunden bei dir.</p>
    </div>
  </div>

  <style>
    :root {
      --bg-primary: #0f172a;
      --bg-secondary: #1e293b;
      --bg-tertiary: #334155;
      --text-primary: #f1f5f9;
      --text-secondary: #94a3b8;
      --accent-blue: #3b82f6;
      --accent-gold: #c9a959;
      --border-radius: 16px;
    }

    .order-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem;
    }

    .order-header {
      text-align: center;
      margin-bottom: 3rem;
    }

    h1 {
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
      background: linear-gradient(135deg, var(--text-primary), var(--accent-blue));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .subtitle {
      color: var(--text-secondary);
      font-size: 1.125rem;
    }

    .progress-bar {
      height: 4px;
      background: var(--bg-tertiary);
      border-radius: 2px;
      margin: 2rem 0 1rem;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent-blue), var(--accent-gold));
      width: 20%;
      transition: width 0.3s ease;
    }

    .step-indicators {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
    }

    .step {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: var(--bg-tertiary);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.625rem;
      color: var(--text-secondary);
    }

    .step.active {
      background: var(--accent-blue);
      color: white;
    }

    .order-form {
      background: var(--bg-secondary);
      padding: 2rem;
      border-radius: var(--border-radius);
      border: 1px solid rgba(59, 130, 246, 0.1);
    }

    fieldset {
      border: none;
      padding: 0;
    }

    legend {
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      color: var(--text-primary);
    }

    .step-description {
      color: var(--text-secondary);
      margin-bottom: 1.5rem;
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    label {
      display: block;
      margin-bottom: 0.5rem;
      font-weight: 500;
      color: var(--text-primary);
    }

    input[type="text"],
    input[type="email"],
    input[type="tel"],
    input[type="url"],
    input[type="number"],
    select,
    textarea {
      width: 100%;
      padding: 0.875rem 1rem;
      background: var(--bg-tertiary);
      border: 1px solid rgba(59, 130, 246, 0.2);
      border-radius: 8px;
      color: var(--text-primary);
      font-size: 1rem;
      transition: border-color 0.3s ease;
    }

    input:focus,
    select:focus,
    textarea:focus {
      outline: none;
      border-color: var(--accent-blue);
    }

    textarea {
      resize: vertical;
      font-family: inherit;
    }

    select[multiple] {
      height: 150px;
    }

    .hint {
      display: block;
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin-top: 0.375rem;
    }

    .competency-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 0.75rem;
      margin-bottom: 1.5rem;
      max-height: 400px;
      overflow-y: auto;
      padding: 1rem;
      background: var(--bg-tertiary);
      border-radius: 8px;
    }

    .competency-option {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      cursor: pointer;
      padding: 0.5rem;
      border-radius: 6px;
      transition: background 0.2s;
    }

    .competency-option:hover {
      background: rgba(59, 130, 246, 0.1);
    }

    .competency-option input {
      width: auto;
      margin: 0;
    }

    .competency-option span {
      font-size: 0.875rem;
      color: var(--text-primary);
    }

    .checkbox-group {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .checkbox-label {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      cursor: pointer;
    }

    .checkbox-label input {
      width: auto;
    }

    .location-entry {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }

    .location-entry input {
      padding: 0.5rem;
      font-size: 0.875rem;
    }

    .template-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .template-option {
      cursor: pointer;
    }

    .template-option input {
      display: none;
    }

    .template-preview {
      padding: 1rem;
      background: var(--bg-tertiary);
      border: 2px solid rgba(59, 130, 246, 0.2);
      border-radius: 12px;
      text-align: center;
      transition: all 0.3s ease;
    }

    .template-option input:checked + .template-preview {
      border-color: var(--accent-blue);
      background: rgba(59, 130, 246, 0.1);
    }

    .preview-colors {
      display: flex;
      justify-content: center;
      gap: 0.25rem;
      margin-bottom: 0.5rem;
    }

    .color {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      display: inline-block;
    }

    .template-name {
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .pricing-selector {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .pricing-option {
      cursor: pointer;
    }

    .pricing-option input {
      display: none;
    }

    .pricing-card {
      padding: 1.5rem;
      background: var(--bg-tertiary);
      border: 2px solid rgba(59, 130, 246, 0.2);
      border-radius: 12px;
      text-align: center;
      transition: all 0.3s ease;
      position: relative;
    }

    .pricing-option input:checked + .pricing-card {
      border-color: var(--accent-blue);
      background: rgba(59, 130, 246, 0.1);
    }

    .pricing-card.featured {
      border-color: var(--accent-blue);
      box-shadow: 0 0 30px rgba(59, 130, 246, 0.2);
    }

    .badge {
      position: absolute;
      top: -10px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--accent-blue);
      color: white;
      padding: 0.25rem 1rem;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
    }

    .price {
      font-size: 2rem;
      font-weight: 700;
      margin: 1rem 0;
      color: var(--text-primary);
    }

    .price span {
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .pricing-card ul {
      list-style: none;
      text-align: left;
      margin-top: 1rem;
      padding-left: 0.5rem;
    }

    .pricing-card li {
      padding: 0.375rem 0;
      color: var(--text-secondary);
      font-size: 0.875rem;
    }

    .form-nav {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      margin-top: 2rem;
      padding-top: 2rem;
      border-top: 1px solid rgba(59, 130, 246, 0.1);
    }

    .btn {
      padding: 0.875rem 2rem;
      border-radius: 8px;
      font-weight: 600;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.3s ease;
      border: none;
    }

    .btn-prev,
    .btn-next {
      background: transparent;
      color: var(--text-secondary);
      border: 2px solid var(--text-secondary);
    }

    .btn-prev:hover,
    .btn-next:hover {
      border-color: var(--text-primary);
      color: var(--text-primary);
    }

    .btn-primary {
      background: var(--accent-blue);
      color: white;
    }

    .btn-primary:hover {
      background: #2563eb;
      transform: translateY(-2px);
    }

    .btn-submit {
      width: 100%;
    }

    .btn-small {
      padding: 0.5rem 1rem;
      font-size: 0.875rem;
      margin-top: 0.5rem;
    }

    .success-message {
      text-align: center;
      padding: 3rem;
      background: var(--bg-secondary);
      border-radius: var(--border-radius);
    }

    .success-icon {
      width: 80px;
      height: 80px;
      margin: 0 auto 1.5rem;
      background: linear-gradient(135deg, var(--accent-blue), var(--accent-gold));
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3rem;
      color: white;
    }

    .success-message h2 {
      font-size: 2rem;
      margin-bottom: 1rem;
    }

    .success-message p {
      color: var(--text-secondary);
      font-size: 1.125rem;
    }

    @media (max-width: 768px) {
      .order-container {
        padding: 1rem;
      }

      .competency-grid {
        grid-template-columns: 1fr;
        max-height: none;
      }

      .location-entry {
        grid-template-columns: 1fr;
      }

      .pricing-selector {
        grid-template-columns: 1fr;
      }

      .template-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>

  <script is:inline>
    let currentStep = 1;
    const totalSteps = 5;

    function updateProgress() {
      const progress = (currentStep / totalSteps) * 100;
      document.getElementById('progress').style.width = `${progress}%`;
      
      document.querySelectorAll('.step').forEach(step => {
        const stepNum = parseInt(step.dataset.step);
        step.classList.toggle('active', stepNum <= currentStep);
      });
    }

    // Expose functions to global scope for onclick handlers
    window.nextStep = function(targetStep) {
      // Validate current step
      const currentFieldset = document.querySelector(`fieldset[data-step="${currentStep}"]`);
      const requiredFields = currentFieldset.querySelectorAll('[required]');
      
      let isValid = true;
      requiredFields.forEach(field => {
        if (field.type === 'checkbox') {
          // For checkbox groups, check if at least one is checked
          const groupName = field.name;
          const groupCheckboxes = currentFieldset.querySelectorAll(`input[name="${groupName}"]`);
          const anyChecked = Array.from(groupCheckboxes).some(cb => cb.checked);
          if (!anyChecked) {
            isValid = false;
            groupCheckboxes.forEach(cb => {
              cb.parentElement.style.color = '#dc2626';
            });
          } else {
            groupCheckboxes.forEach(cb => {
              cb.parentElement.style.color = '';
            });
          }
        } else if (!field.value.trim()) {
          isValid = false;
          field.style.borderColor = '#dc2626';
        } else {
          field.style.borderColor = '';
        }
      });

      if (!isValid) {
        alert('Bitte fülle alle Pflichtfelder aus.');
        return;
      }

      // Hide current step
      document.querySelector(`fieldset[data-step="${currentStep}"]`).hidden = true;
      
      // Show next step
      currentStep = targetStep;
      document.querySelector(`fieldset[data-step="${currentStep}"]`).hidden = false;
      
      updateProgress();
    };

    window.prevStep = function(targetStep) {
      document.querySelector(`fieldset[data-step="${currentStep}"]`).hidden = true;
      currentStep = targetStep;
      document.querySelector(`fieldset[data-step="${currentStep}"]`).hidden = false;
      updateProgress();
    };

    window.addLocationField = function() {
      const locationContainer = document.getElementById('physical-locations');
      const newEntry = document.createElement('div');
      newEntry.className = 'location-entry';
      newEntry.innerHTML = `
        <input type="text" name="locationCity[]" placeholder="Stadt" />
        <input type="text" name="locationCountry[]" placeholder="Land" />
      `;
      locationContainer.insertBefore(newEntry, locationContainer.querySelector('button'));
    };

    // Toggle physical locations based on onsite/hybrid selection
    function toggleLocationFields() {
      const onsite = document.getElementById('mode-onsite');
      const hybrid = document.getElementById('mode-hybrid');
      const locationContainer = document.getElementById('physical-locations');
      locationContainer.hidden = !(onsite?.checked || hybrid?.checked);
    }

    document.getElementById('mode-online')?.addEventListener('change', toggleLocationFields);
    document.getElementById('mode-onsite')?.addEventListener('change', toggleLocationFields);
    document.getElementById('mode-hybrid')?.addEventListener('change', toggleLocationFields);

    // Character counters
    const certTextarea = document.getElementById('certifications');
    const certCount = document.getElementById('cert-count');
    certTextarea?.addEventListener('input', () => {
      certCount.textContent = certTextarea.value.length;
    });

    const requestsTextarea = document.getElementById('requests');
    const requestsCount = document.getElementById('requests-count');
    requestsTextarea?.addEventListener('input', () => {
      requestsCount.textContent = requestsTextarea.value.length;
    });

    // Form submission
    document.getElementById('order-form')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const formData = new FormData(this);
      const data = Object.fromEntries(formData.entries());
      
      // Handle arrays (competencies, languages, locations)
      data.competencies = formData.getAll('competencies');
      data.languages = formData.getAll('languages');
      data.coachingModes = formData.getAll('coachingModes');
      data.locationCities = formData.getAll('locationCity[]');
      data.locationCountries = formData.getAll('locationCountry[]');
      
      // Show loading state
      const submitBtn = this.querySelector('button[type="submit"]');
      const originalText = submitBtn?.textContent || 'Jetzt bestellen';
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Wird gesendet...';
      }
      
      try {
        const response = await fetch('/api/order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        
        if (response.ok) {
          const result = await response.json();
          // Redirect to thank you page with order ID
          window.location.href = `/order/thanks?orderId=${result.orderId}`;
        } else {
          const error = await response.json();
          alert(`Fehler beim Senden: ${error.error || 'Bitte versuche es erneut.'}`);
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = originalText;
          }
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Fehler beim Senden. Bitte versuche es erneut.');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = originalText;
        }
      }
    });

    // Initialize
    updateProgress();
  </script>
</BaseLayout>
