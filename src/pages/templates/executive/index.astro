---
import BaseLayout from '../../layouts/Base.astro';
---
<BaseLayout title="Executive Template | Jobcoach Website" description="Executive Design für Jobcoaches – klassisch, elegant, kompetent.">
  <div class="demo-page">
    <header class="demo-header">
      <div class="demo-badge">Executive Template</div>
      <a href="/order?template=executive" class="btn-use">Dieses Template wählen →</a>
    </header>

    <!-- Hero -->
    <section class="hero executive-hero">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="hero-content">
        <span class="badge">Executive Design</span>
        <h1>Dr. Katharina Weber</h1>
        <p class="subtitle">Zertifizierte Karriereberaterin (ICF)<br/>20+ Jahre Erfahrung in Strategieberatung & Leadership</p>
        
        <div class="credentials">
          <span class="credential-badge">ICF Master Coach</span>
          <span class="credential-badge">DBVC zertifiziert</span>
          <span class="credential-badge">AZWV-anerkannt</span>
        </div>

        <div class="cta-group">
          <a href="#angebot" class="btn btn-primary">Termin buchen</a>
          <a href="#ueber-mich" class="btn btn-secondary">Mehr erfahren</a>
        </div>
      </div>
    </section>

    <!-- About -->
    <section class="about" id="ueber-mich">
      <div class="about-grid">
        <div class="about-text">
          <h2>Über mich</h2>
          <p>Als ehemalige McKinsey-Partnerin und langjährige Führungskraft weiß ich, worauf es bei beruflicher Transformation wirklich ankommt. Mein Ansatz verbindet strategische Klarheit mit menschlicher Wärme.</p>
          <p>Meine Klienten sind Executives, Aufsichtsräte und Fachkräfte, die den nächsten Schritt in ihrer Karriere planen – sei es ein C-Level-Wechsel, eine Branchen Pivot oder ein vollständiger Neuanfang.</p>
        </div>
        <div class="about-image">
          <div class="profile-placeholder" style="background: linear-gradient(135deg, #1e3a5f, #2d4a6f);">
            <span>KW</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Services -->
    <section class="services" id="angebot">
      <h2>Meine Leistungen</h2>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">🎯</div>
          <h3>Executive Coaching</h3>
          <p>Intensive 1:1 Begleitung für Führungskräfte in Transition. 12-wöchiges Programm mit wöchentlichen Sessions.</p>
          <div class="price">ab €3.200</div>
        </div>
        <div class="service-card">
          <div class="service-icon">📊</div>
          <h3>Karriere-Strategie</h3>
          <p>Deep-Dive Workshops zur beruflichen Neuausrichtung. Inkl. Marktanalysen und Positionspapier.</p>
          <div class="price">ab €1.800</div>
        </div>
        <div class="service-card">
          <div class="service-icon">💼</div>
          <h3>Bewerbungscoaching</h3>
          <p>Von LinkedIn-Optimierung bis Interview-Coaching – für Positionen ab €120K Jahresgehalt.</p>
          <div class="price">ab €890</div>
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="testimonial">
      <blockquote>
        "Katharina hat mir geholen, meine Werte zu klären und eine Strategie für den Vorstandswechsel zu entwickeln. In 6 Monaten habe ich zwei Angebote bekommen."
      </blockquote>
      <cite>— Dr. Marcus Stein, CFO, Munich</cite>
    </section>

    <!-- Contact CTA -->
    <section class="contact-cta">
      <h2>Bereit für den nächsten Schritt?</h2>
      <p>Booken Sie ein kostenloses 30-Minuten Discovery-Call.</p>
      <a href="/order?template=executive" class="btn btn-primary btn-large">
        Erstgespräch vereinbaren
      </a>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <p>© 2026 Katharina Weber Coaching · Change-to-Impact Partner</p>
      <p class="legal-links">
        <a href="/impressum">Impressum</a> · <a href="/datenschutz">Datenschutz</a>
      </p>
    </footer>
  </div>
</BaseLayout>

<style is:global>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: #0f172a;
    color: #f1f5f9;
    line-height: 1.6;
  }
</style>

<style>
  :root {
    --primary: #1e3a5f;
    --primary-light: #2d5a8f;
    --accent: #c9a959;
    --accent-light: #e0c47a;
    --bg-dark: #0f172a;
    --bg-card: rgba(30, 58, 95, 0.6);
    --text: #f1f5f9;
    --text-muted: #94a3b8;
  }

  .demo-page { min-height: 100vh; overflow-x: hidden; }

  .demo-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    background: rgba(15, 23, 42, 0.9);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(201, 169, 89, 0.2);
  }

  .demo-badge {
    background: rgba(201, 169, 89, 0.15);
    border: 1px solid rgba(201, 169, 89, 0.3);
    color: var(--accent);
    padding: 8px 16px;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .btn-use {
    background: var(--accent);
    color: #0f172a;
    padding: 10px 20px;
    border-radius: 10px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-use:hover {
    background: var(--accent-light);
    transform: translateY(-2px);
    text-decoration: none;
  }

  /* Hero */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 2rem 4rem;
    background: radial-gradient(ellipse at 50% 0%, rgba(30, 58, 95, 0.3) 0%, transparent 60%);
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.4;
    animation: float 10s ease-in-out infinite;
  }

  .orb-1 {
    width: 500px; height: 500px;
    background: var(--primary);
    top: -150px; left: -150px;
  }

  .orb-2 {
    width: 400px; height: 400px;
    background: var(--accent);
    bottom: -100px; right: -100px;
    opacity: 0.2;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(20px, -20px); }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
    text-align: center;
  }

  .badge {
    display: inline-block;
    padding: 8px 16px;
    background: rgba(201, 169, 89, 0.15);
    border: 1px solid rgba(201, 169, 89, 0.3);
    border-radius: 100px;
    font-size: 0.85rem;
    color: var(--accent);
    margin-bottom: 2rem;
  }

  .hero h1 {
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto 2rem;
  }

  .credentials {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .credential-badge {
    background: rgba(201, 169, 89, 0.1);
    border: 1px solid rgba(201, 169, 89, 0.3);
    color: var(--accent);
    padding: 6px 14px;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .cta-group {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 12px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent), #a08040);
    color: #0f172a;
    box-shadow: 0 4px 20px rgba(201, 169, 89, 0.3);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(201, 169, 89, 0.4);
    text-decoration: none;
  }

  .btn-secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid rgba(255,255,255,0.2);
  }

  .btn-secondary:hover {
    background: rgba(255,255,255,0.1);
    text-decoration: none;
  }

  .btn-large { padding: 18px 36px; font-size: 1.1rem; }

  /* About */
  .about {
    padding: 6rem 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 4rem;
    align-items: center;
  }

  .about h2 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    color: var(--accent);
  }

  .about p {
    color: var(--text-muted);
    margin-bottom: 1rem;
    font-size: 1.05rem;
  }

  .profile-placeholder {
    width: 280px;
    height: 350px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    font-weight: 700;
    color: rgba(255,255,255,0.3);
  }

  /* Services */
  .services {
    padding: 6rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .services h2 {
    font-size: 2.5rem;
    text-align: center;
    margin-bottom: 3rem;
    color: var(--accent);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .service-card {
    background: var(--bg-card);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(201, 169, 89, 0.15);
    border-radius: 20px;
    padding: 2.5rem;
    transition: all 0.3s ease;
  }

  .service-card:hover {
    transform: translateY(-4px);
    border-color: rgba(201, 169, 89, 0.4);
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }

  .service-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .service-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .service-card p {
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .price {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent);
  }

  /* Testimonial */
  .testimonial {
    padding: 6rem 2rem;
    text-align: center;
    background: linear-gradient(135deg, rgba(30, 58, 95, 0.3), rgba(201, 169, 89, 0.1));
  }

  .testimonial blockquote {
    font-size: 1.5rem;
    font-style: italic;
    color: var(--text);
    max-width: 700px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .testimonial cite {
    color: var(--accent);
    font-size: 1rem;
  }

  /* Contact CTA */
  .contact-cta {
    padding: 6rem 2rem;
    text-align: center;
  }

  .contact-cta h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .contact-cta p {
    color: var(--text-muted);
    margin-bottom: 2rem;
    font-size: 1.1rem;
  }

  /* Footer */
  .footer {
    padding: 2rem;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .legal-links {
    margin-top: 0.75rem;
  }

  .legal-links a {
    color: var(--text-muted);
    text-decoration: none;
  }

  .legal-links a:hover {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; }
    .profile-placeholder { width: 100%; height: 250px; margin: 0 auto; }
    .hero h1 { font-size: 2.5rem; }
    .services h2, .contact-cta h2 { font-size: 1.75rem; }
  }
</style>