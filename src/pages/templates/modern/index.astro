---
import BaseLayout from '../../../layouts/Base.astro';
---
<BaseLayout title="Modern Template | Jobcoach Website" description="Modernes Design für Jobcoaches – frisch, dynamisch, zukunftsorientiert.">
  <div class="demo-page">
    <header class="demo-header">
      <div class="demo-badge">Modern Template</div>
      <a href="/order?template=modern" class="btn-use">Dieses Template wählen →</a>
    </header>

    <!-- Hero -->
    <section class="hero modern-hero">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
      <div class="hero-content">
        <span class="badge">Modern Design</span>
        <h1>Sarah Chen</h1>
        <p class="subtitle">Agile Coach & Karriere-Expertin<br/>Ich helfe dir, deinen Traumjob zu finden – schneller als du denkst.</p>
        
        <div class="credentials">
          <span class="credential-badge">✓ SCRUM Master</span>
          <span class="credential-badge">✓ Design Thinking</span>
          <span class="credential-badge">✓ system. Coach</span>
        </div>

        <div class="cta-group">
          <a href="#angebot" class="btn btn-primary">Kostenloses Erstgespräch</a>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="stats">
      <div class="stat-item">
        <div class="stat-number">500+</div>
        <div class="stat-label">Erfolgreiche Coaches</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">98%</div>
        <div class="stat-label">Kundenzufriedenheit</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">15 Min</div>
        <div class="stat-label">bis zur ersten Analyse</div>
      </div>
    </section>

    <!-- About -->
    <section class="about" id="ueber-mich">
      <div class="about-content">
        <h2>Hi, ich bin Sarah 👋</h2>
        <p>Ich bin selbst den schwierigen Karriereweg gegangen – vom 9-to-5 zur Selbstständigkeit. Heute helfe ich anderen, schneller ans Ziel zu kommen. Mein Ansatz: datenbasiert, pragmatisch und immer auf dem neuesten Stand.</p>
        <p>Ob du gerade deinen Job verloren hast, dich neu orientieren willst oder den nächsten Karrieresprung planst – ich habe die Tools und die Erfahrung, dir zu helfen.</p>
      </div>
    </section>

    <!-- Services -->
    <section class="services" id="angebot">
      <h2>Was ich für dich tun kann</h2>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">🚀</div>
          <h3>Karriere-Launch</h3>
          <p>Dein kompletter Fahrplan zum Traumjob – inkl. CV, LinkedIn-Optimierung und Interview-Vorbereitung.</p>
          <div class="price">€49<span>/Monat</span></div>
        </div>
        <div class="service-card featured">
          <div class="badge-popular">Beliebt</div>
          <div class="service-icon">⚡</div>
          <h3>Power Coaching</h3>
          <p>8 Wochen intensive Begleitung mit wöchentlichen Sessions, Messaging-Strategie und Rollenspielen.</p>
          <div class="price">€199<span>/Monat</span></div>
        </div>
        <div class="service-card">
          <div class="service-icon">🎯</div>
          <h3>Snapshot Review</h3>
          <p>60-Minütige Tiefen-Analyse deiner aktuellen Situation + konkreter Aktionsplan.</p>
          <div class="price">€89<span>/Session</span></div>
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="process">
      <h2>So starten wir</h2>
      <div class="process-steps">
        <div class="process-step">
          <div class="step-num">01</div>
          <h3>Gratis Discovery</h3>
          <p>15 Minuten, um deine Situation zu verstehen und zu prüfen, ob wir zusammenpassen.</p>
        </div>
        <div class="process-step">
          <div class="step-num">02</div>
          <h3>Analyse</h3>
          <p>Ich erstelle eine detaillierte Karriere-Analyse basierend auf deinen Zielen und dem Markt.</p>
        </div>
        <div class="process-step">
          <div class="step-num">03</div>
          <h3>Umsetzung</h3>
          <p>Together setzen wir deinen Plan um – mit wöchentlichen Check-ins und Anpassungen.</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="contact-cta">
      <h2>Let's do this! 🚀</h2>
      <p>Die erste Session ist kostenlos. Kein Risiko, kein Druck.</p>
      <a href="/order?template=modern" class="btn btn-primary btn-large">
        Jetzt starten
      </a>
    </section>

    <footer class="footer">
      <p>© 2026 Sarah Chen Coaching · Change-to-Impact Partner</p>
      <p class="legal-links">
        <a href="/impressum">Impressum</a> · <a href="/datenschutz">Datenschutz</a>
      </p>
    </footer>
  </div>
</BaseLayout>

<style is:global>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: #0f172a;
    color: #f1f5f9;
    line-height: 1.6;
  }
</style>

<style>
  :root {
    --primary: #2563eb;
    --primary-dark: #1d4ed8;
    --accent: #10b981;
    --accent-light: #34d399;
    --bg-dark: #0f172a;
    --bg-card: rgba(30, 41, 59, 0.8);
    --text: #f1f5f9;
    --text-muted: #94a3b8;
  }

  .demo-page { min-height: 100vh; overflow-x: hidden; }

  .demo-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    background: rgba(15, 23, 42, 0.9);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(37, 99, 235, 0.2);
  }

  .demo-badge {
    background: rgba(16, 185, 129, 0.15);
    border: 1px solid rgba(16, 185, 129, 0.3);
    color: var(--accent);
    padding: 8px 16px;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .btn-use {
    background: var(--accent);
    color: #0f172a;
    padding: 10px 20px;
    border-radius: 10px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-use:hover {
    background: var(--accent-light);
    transform: translateY(-2px);
    text-decoration: none;
  }

  /* Hero */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 2rem 4rem;
    background: radial-gradient(ellipse at 50% 0%, rgba(37, 99, 235, 0.2) 0%, transparent 60%);
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    animation: float 8s ease-in-out infinite;
  }

  .orb-1 {
    width: 400px; height: 400px;
    background: var(--primary);
    top: -100px; right: -100px;
    opacity: 0.5;
  }

  .orb-2 {
    width: 300px; height: 300px;
    background: var(--accent);
    bottom: -50px; left: -50px;
    opacity: 0.4;
    animation-delay: -3s;
  }

  .orb-3 {
    width: 200px; height: 200px;
    background: #06b6d4;
    top: 50%; left: 60%;
    opacity: 0.3;
    animation-delay: -5s;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(20px, -20px); }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
    text-align: center;
  }

  .badge {
    display: inline-block;
    padding: 8px 16px;
    background: rgba(16, 185, 129, 0.15);
    border: 1px solid rgba(16, 185, 129, 0.3);
    border-radius: 100px;
    font-size: 0.85rem;
    color: var(--accent);
    margin-bottom: 2rem;
  }

  .hero h1 {
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto 2rem;
  }

  .credentials {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .credential-badge {
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid rgba(16, 185, 129, 0.3);
    color: var(--accent);
    padding: 6px 14px;
    border-radius: 6px;
    font-size: 0.85rem;
  }

  .cta-group {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 12px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent), #059669);
    color: white;
    box-shadow: 0 4px 20px rgba(16, 185, 129, 0.4);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(16, 185, 129, 0.5);
    text-decoration: none;
  }

  .btn-large { padding: 18px 36px; font-size: 1.1rem; }

  /* Stats */
  .stats {
    display: flex;
    justify-content: center;
    gap: 4rem;
    padding: 4rem 2rem;
    background: rgba(16, 185, 129, 0.05);
    border-top: 1px solid rgba(16, 185, 129, 0.1);
    border-bottom: 1px solid rgba(16, 185, 129, 0.1);
  }

  .stat-item { text-align: center; }

  .stat-number {
    font-size: 3rem;
    font-weight: 800;
    color: var(--accent);
  }

  .stat-label {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }

  /* About */
  .about {
    padding: 6rem 2rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .about-content { text-align: center; }

  .about h2 {
    font-size: 2.5rem;
    margin-bottom: 2rem;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .about p {
    color: var(--text-muted);
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
  }

  /* Services */
  .services {
    padding: 6rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .services h2 {
    font-size: 2.5rem;
    text-align: center;
    margin-bottom: 3rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .service-card {
    background: var(--bg-card);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(37, 99, 235, 0.15);
    border-radius: 20px;
    padding: 2.5rem;
    position: relative;
    transition: all 0.3s ease;
  }

  .service-card.featured {
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.2), rgba(16, 185, 129, 0.1));
    border-color: rgba(16, 185, 129, 0.3);
  }

  .service-card:hover {
    transform: translateY(-4px);
    border-color: rgba(16, 185, 129, 0.4);
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }

  .badge-popular {
    position: absolute;
    top: -12px;
    right: 20px;
    background: var(--accent);
    color: #0f172a;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .service-icon { font-size: 2.5rem; margin-bottom: 1rem; }

  .service-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .service-card p {
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .price {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent);
  }

  .price span { font-size: 0.9rem; color: var(--text-muted); font-weight: 400; }

  /* Process */
  .process {
    padding: 6rem 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .process h2 {
    font-size: 2.5rem;
    text-align: center;
    margin-bottom: 3rem;
  }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .process-step {
    background: var(--bg-card);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(37, 99, 235, 0.15);
    border-radius: 16px;
    padding: 2rem;
    text-align: center;
  }

  .step-num {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .process-step h3 { font-size: 1.1rem; margin-bottom: 0.75rem; }
  .process-step p { color: var(--text-muted); font-size: 0.9rem; }

  /* CTA */
  .contact-cta {
    padding: 6rem 2rem;
    text-align: center;
    background: radial-gradient(ellipse at 50% 100%, rgba(16, 185, 129, 0.15) 0%, transparent 60%);
  }

  .contact-cta h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .contact-cta p {
    color: var(--text-muted);
    margin-bottom: 2rem;
    font-size: 1.1rem;
  }

  /* Footer */
  .footer {
    padding: 2rem;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .legal-links { margin-top: 0.75rem; }
  .legal-links a { color: var(--text-muted); text-decoration: none; }
  .legal-links a:hover { color: var(--accent); }

  @media (max-width: 768px) {
    .stats { flex-direction: column; gap: 2rem; }
    .process-steps { grid-template-columns: 1fr; }
    .hero h1 { font-size: 2.5rem; }
  }
</style>