---
import BaseLayout from '../../../layouts/Base.astro';
---
<BaseLayout title="Glassmorphism Template | Jobcoach Website" description="Modernes Glassmorphism + Bento Grid Design für Jobcoaches – futuristisch, elegant, innovativ.">
  <div class="demo-page">
    <header class="demo-header">
      <div class="demo-badge">✨ Glassmorphism Template</div>
      <a href="/order?template=glassmorphism" class="btn-use">Dieses Template wählen →</a>
    </header>

    <!-- Hero -->
    <section class="hero glassmorphism-hero">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
      <div class="orb orb-4"></div>
      
      <div class="hero-content">
        <div class="glass-card hero-glass">
          <span class="badge-glow">✨ Bento + Glass</span>
          <h1>Lena Fischer</h1>
          <p class="subtitle">Innovative Jobcoachin · Berlin<br/>Ich verwandle Karriere-Chancen in Erfolgsgeschichten.</p>
          
          <div class="glass-pills">
            <span class="glass-pill">🎯 Strategic Coach</span>
            <span class="glass-pill">🚀 Career Pivot Expert</span>
            <span class="glass-pill">💡 Innovation Trainer</span>
          </div>

          <div class="cta-group">
            <a href="#bento" class="btn btn-glow btn-large">Entdecke meine Welt →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Bento Grid -->
    <section class="bento-section" id="bento">
      <div class="bento-grid">
        <!-- Large featured card -->
        <div class="bento-card bento-large glass-card">
          <div class="card-glow"></div>
          <div class="card-icon-lg">🎯</div>
          <h3>Strategic Career Design</h3>
          <p>Dein Karriere-Masterplan in 8 Wochen. Data-driven, personalisiert, messbar.</p>
          <div class="card-shimmer"></div>
          <div class="card-price">€199<span>/Monat</span></div>
        </div>

        <!-- Stats card -->
        <div class="bento-card glass-card">
          <div class="card-glow"></div>
          <div class="stats-grid">
            <div class="stat">
              <div class="stat-num">600+</div>
              <div class="stat-label">Klienten</div>
            </div>
            <div class="stat">
              <div class="stat-num">97%</div>
              <div class="stat-label">Erfolg</div>
            </div>
            <div class="stat">
              <div class="stat-num">4.9★</div>
              <div class="stat-label">Bewertung</div>
            </div>
          </div>
        </div>

        <!-- Expertise card -->
        <div class="bento-card glass-card">
          <div class="card-glow"></div>
          <h3>Expertise</h3>
          <div class="expertise-list">
            <span class="expertise-tag">Tech Industry</span>
            <span class="expertise-tag">Startup Founders</span>
            <span class="expertise-tag">Career Pivot</span>
            <span class="expertise-tag">Leadership</span>
            <span class="expertise-tag">Negotiation</span>
            <span class="expertise-tag">Personal Brand</span>
          </div>
        </div>

        <!-- Process card -->
        <div class="bento-card glass-card">
          <div class="card-glow"></div>
          <h3>Mein Process</h3>
          <div class="process-list">
            <div class="process-item">
              <span class="process-num">01</span>
              <span>Deep Dive Analyse</span>
            </div>
            <div class="process-item">
              <span class="process-num">02</span>
              <span>Strategy Blueprint</span>
            </div>
            <div class="process-item">
              <span class="process-num">03</span>
              <span>Execution Sprint</span>
            </div>
          </div>
        </div>

        <!-- Testimonial card -->
        <div class="bento-card bento-wide glass-card">
          <div class="card-glow"></div>
          <div class="testimonial-content">
            <div class="quote-icon">"</div>
            <p>Lenens Glassmorphism-Ansatz hat meine Karriere revolutioniert. In 3 Monaten von Team Lead zu VP.</p>
            <div class="testimonial-author">
              <div class="author-avatar">JM</div>
              <div>
                <div class="author-name">Julia M.</div>
                <div class="author-role">VP Product, Berlin</div>
              </div>
            </div>
          </div>
          <div class="card-shimmer"></div>
        </div>

        <!-- CTA card -->
        <div class="bento-card glass-card cta-card">
          <div class="card-glow"></div>
          <h3>Bereit für den Next Level?</h3>
          <p>Booke jetzt dein kostenloses Discovery Call.</p>
          <a href="/order?template=glassmorphism" class="btn btn-glow">Let's go! 🚀</a>
        </div>

        <!-- Social proof card -->
        <div class="bento-card glass-card">
          <div class="card-glow"></div>
          <h3>Zertifizierungen</h3>
          <div class="cert-logos">
            <div class="cert-badge glass-badge">ICF</div>
            <div class="cert-badge glass-badge">DBVC</div>
            <div class="cert-badge glass-badge">AZWV</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Detail -->
    <section class="services-section">
      <div class="services-header">
        <h2>Was wir gemeinsam bauen</h2>
        <p>Alles aus einem Guss – transparent, effektiv, results-oriented.</p>
      </div>
      
      <div class="services-cards">
        <div class="service-glass glass-card">
          <div class="service-glow"></div>
          <div class="service-icon">🚀</div>
          <h3>Career Acceleration</h3>
          <p>6-Wochen Programm für Professionals, die den nächsten Schritt wollen. Inkl. Personal Brand + Interview Prep.</p>
          <div class="service-price">€890<span>/Programm</span></div>
          <a href="/order?template=glassmorphism" class="btn btn-glow btn-small">Start now →</a>
        </div>

        <div class="service-glass glass-card featured-service">
          <div class="service-glow"></div>
          <div class="badge-crown">★ Most Popular</div>
          <div class="service-icon">⚡</div>
          <h3>Glass Coaching</h3>
          <p>12 Wochen intensive 1:1 Begleitung. Wöchentliche Sessions + Slack-Support + Notfall-Hotline.</p>
          <div class="service-price">€2.200<span>/Quartal</span></div>
          <a href="/order?template=glassmorphism" class="btn btn-glow btn-small">Book Session →</a>
        </div>

        <div class="service-glass glass-card">
          <div class="service-glow"></div>
          <div class="service-icon">🎯</div>
          <h3>Executive Compact</h3>
          <p>4-Wochen Sprint für C-Level und Aufsichtsräte. Strategische Karriere-Planung + Gehaltsverhandlung.</p>
          <div class="service-price">€3.500<span>/Sprint</span></div>
          <a href="/order?template=glassmorphism" class="btn btn-glow btn-small">Learn more →</a>
        </div>
      </div>
    </section>

    <!-- Footer CTA -->
    <section class="footer-cta">
      <div class="footer-glass glass-card">
        <div class="card-glow"></div>
        <h2>Deine Glassmorphism Website wartet ✨</h2>
        <p>Wähle dieses Template und bekomme eine futuristische, moderne Coach-Website.</p>
        <a href="/order?template=glassmorphism" class="btn btn-glow btn-large">
          Jetzt starten →
        </a>
      </div>
    </section>

    <footer class="footer">
      <p>© 2026 Lena Fischer Coaching · Change-to-Impact Partner</p>
      <p class="legal-links">
        <a href="/impressum">Impressum</a> · <a href="/datenschutz">Datenschutz</a>
      </p>
    </footer>
  </div>
</BaseLayout>

<style is:global>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: #030712;
    color: #f1f5f9;
    line-height: 1.6;
  }
</style>

<style>
  :root {
    --primary: #8b5cf6;
    --primary-light: #a78bfa;
    --primary-dark: #7c3aed;
    --accent: #06b6d4;
    --accent-light: #22d3ee;
    --pink: #ec4899;
    --bg-dark: #030712;
    --glass-bg: rgba(255, 255, 255, 0.05);
    --glass-border: rgba(255, 255, 255, 0.1);
    --text: #f1f5f9;
    --text-muted: #94a3b8;
  }

  .demo-page { 
    min-height: 100vh; 
    overflow-x: hidden;
    background: #030712;
  }

  /* ========== HEADER ========== */
  .demo-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    background: rgba(3, 7, 18, 0.8);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(139, 92, 246, 0.2);
  }

  .demo-badge {
    background: rgba(139, 92, 246, 0.15);
    border: 1px solid rgba(139, 92, 246, 0.3);
    color: var(--primary-light);
    padding: 8px 16px;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .btn-use {
    background: linear-gradient(135deg, var(--primary), var(--primary-dark));
    color: white;
    padding: 10px 20px;
    border-radius: 10px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3);
  }

  .btn-use:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(139, 92, 246, 0.4);
    text-decoration: none;
  }

  /* ========== HERO ========== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8rem 2rem 4rem;
    overflow: hidden;
  }

  .glassmorphism-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse at 30% 20%, rgba(139, 92, 246, 0.15) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 60%, rgba(6, 182, 212, 0.1) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 100%, rgba(236, 72, 153, 0.08) 0%, transparent 50%);
    pointer-events: none;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .orb-1 {
    width: 500px; height: 500px;
    background: var(--primary);
    top: -150px; left: -150px;
    opacity: 0.3;
    animation: float1 12s ease-in-out infinite;
  }

  .orb-2 {
    width: 400px; height: 400px;
    background: var(--accent);
    bottom: -100px; right: -100px;
    opacity: 0.2;
    animation: float2 10s ease-in-out infinite;
  }

  .orb-3 {
    width: 300px; height: 300px;
    background: var(--pink);
    top: 40%; left: 60%;
    opacity: 0.15;
    animation: float3 14s ease-in-out infinite;
  }

  .orb-4 {
    width: 200px; height: 200px;
    background: var(--accent-light);
    bottom: 20%; left: 20%;
    opacity: 0.15;
    animation: float1 8s ease-in-out infinite reverse;
  }

  @keyframes float1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(40px, -30px) scale(1.05); }
    66% { transform: translate(-20px, 20px) scale(0.95); }
  }

  @keyframes float2 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-30px, 40px); }
  }

  @keyframes float3 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    50% { transform: translate(20px, -40px) rotate(10deg); }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 900px;
  }

  /* ========== GLASSMORPHISM CARDS ========== */
  .glass-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 24px;
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
    transition: all 0.4s ease;
  }

  .glass-card:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(139, 92, 246, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(139, 92, 246, 0.15), 0 0 40px rgba(139, 92, 246, 0.1);
  }

  .card-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at center, rgba(139, 92, 246, 0.08) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .glass-card:hover .card-glow {
    opacity: 1;
  }

  .card-shimmer {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
    transition: left 0.6s ease;
    pointer-events: none;
  }

  .glass-card:hover .card-shimmer {
    left: 100%;
  }

  /* Hero Glass Card */
  .hero-glass {
    text-align: center;
    padding: 4rem 3rem;
  }

  .badge-glow {
    display: inline-block;
    background: rgba(139, 92, 246, 0.2);
    border: 1px solid rgba(139, 92, 246, 0.4);
    color: var(--primary-light);
    padding: 8px 20px;
    border-radius: 100px;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 2rem;
    animation: pulse-glow 3s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 20px rgba(139, 92, 246, 0.2); }
    50% { box-shadow: 0 0 40px rgba(139, 92, 246, 0.4); }
  }

  .hero h1 {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 800;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #fff, var(--primary-light), var(--accent-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.1;
  }

  .hero .subtitle {
    font-size: 1.2rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .glass-pills {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .glass-pill {
    background: rgba(139, 92, 246, 0.1);
    border: 1px solid rgba(139, 92, 246, 0.2);
    backdrop-filter: blur(10px);
    color: var(--primary-light);
    padding: 8px 16px;
    border-radius: 100px;
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }

  .glass-pill:hover {
    background: rgba(139, 92, 246, 0.2);
    border-color: rgba(139, 92, 246, 0.4);
    transform: translateY(-2px);
  }

  .cta-group { display: flex; justify-content: center; }

  /* ========== BENTO GRID ========== */
  .bento-section {
    padding: 4rem 2rem 6rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 200px;
    gap: 1.5rem;
  }

  .bento-card {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .bento-card h3 {
    font-size: 1.2rem;
    margin-bottom: 0.75rem;
  }

  .bento-card p {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  /* Bento sizes */
  .bento-large {
    grid-column: span 2;
    grid-row: span 2;
    text-align: center;
    justify-content: center;
    align-items: center;
  }

  .bento-large .card-icon-lg {
    font-size: 4rem;
    margin-bottom: 1rem;
  }

  .bento-large h3 {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .bento-wide {
    grid-column: span 2;
  }

  /* Card price */
  .card-price {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--primary-light);
    margin-top: 1rem;
  }

  .card-price span {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 400;
  }

  /* Stats grid */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    width: 100%;
  }

  .stat { text-align: center; }

  .stat-num {
    font-size: 1.75rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--primary-light), var(--accent-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-label {
    color: var(--text-muted);
    font-size: 0.8rem;
    margin-top: 0.25rem;
  }

  /* Expertise tags */
  .expertise-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .expertise-tag {
    background: rgba(139, 92, 246, 0.1);
    border: 1px solid rgba(139, 92, 246, 0.2);
    color: var(--primary-light);
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 0.8rem;
    transition: all 0.3s ease;
  }

  .expertise-tag:hover {
    background: rgba(139, 92, 246, 0.2);
    transform: translateY(-1px);
  }

  /* Process list */
  .process-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .process-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .process-num {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--primary-light);
    background: rgba(139, 92, 246, 0.15);
    padding: 2px 8px;
    border-radius: 6px;
  }

  /* Testimonial */
  .testimonial-content { width: 100%; }

  .quote-icon {
    font-size: 4rem;
    color: var(--primary-light);
    opacity: 0.3;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .testimonial-content p {
    font-size: 1.1rem;
    font-style: italic;
    margin-bottom: 1.5rem;
    color: var(--text);
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .author-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.9rem;
  }

  .author-name {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .author-role {
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  /* CTA card */
  .cta-card {
    text-align: center;
    justify-content: center;
    align-items: center;
    grid-column: span 1;
  }

  .cta-card h3 { font-size: 1.1rem; }
  .cta-card p { font-size: 0.9rem; margin-bottom: 1rem; }

  /* Cert badges */
  .cert-logos {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .glass-badge {
    background: rgba(139, 92, 246, 0.1);
    border: 1px solid rgba(139, 92, 246, 0.3);
    color: var(--primary-light);
    padding: 8px 16px;
    border-radius: 10px;
    font-size: 0.85rem;
    font-weight: 700;
  }

  /* ========== BUTTONS ========== */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .btn-glow {
    background: linear-gradient(135deg, var(--primary), var(--primary-dark));
    color: white;
    box-shadow: 0 4px 20px rgba(139, 92, 246, 0.4), 0 0 40px rgba(139, 92, 246, 0.1);
    position: relative;
    overflow: hidden;
  }

  .btn-glow::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    transition: left 0.5s ease;
  }

  .btn-glow:hover::before {
    left: 100%;
  }

  .btn-glow:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(139, 92, 246, 0.5), 0 0 60px rgba(139, 92, 246, 0.2);
    text-decoration: none;
  }

  .btn-large { padding: 18px 36px; font-size: 1.1rem; }
  .btn-small { padding: 10px 20px; font-size: 0.9rem; }

  /* ========== SERVICES SECTION ========== */
  .services-section {
    padding: 4rem 2rem 6rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .services-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .services-header h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .services-header p {
    color: var(--text-muted);
    font-size: 1.1rem;
  }

  .services-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .service-glass {
    padding: 2.5rem;
    text-align: center;
    position: relative;
  }

  .service-glass.featured-service {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.15), rgba(6, 182, 212, 0.08));
    border-color: rgba(139, 92, 246, 0.3);
  }

  .service-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 0%, rgba(139, 92, 246, 0.1) 0%, transparent 60%);
    pointer-events: none;
  }

  .badge-crown {
    position: absolute;
    top: -12px;
    right: 20px;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    color: white;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .service-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .service-glass h3 {
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
  }

  .service-glass p {
